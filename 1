<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>我的第一个网页</title>
    <style>
        /* 这里开始布置样式 */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* 顶部 */
        .header {
            background: #333;
            color: white;
            padding: 20px;
            text-align: center;
        }

        /* 中间内容 */
        .content {
            width: 80%;
            margin: 30px auto; /* 自动居中 */
            line-height: 1.6;
        }

        /* 底部 */
        .footer {
            background: #333;
            color: white;
            text-align: center;
            padding: 15px;
            margin-top: 50px;
        }
    </style>
</head>

<body>
    <!-- 顶部 -->
    <div class="header">我是网页顶部</div>

    <!-- 中间内容 -->
    <div class="content">
        <h1>欢迎来到我的网页</h1>
        <p>这里可以写文字</p>
        <p>这里可以放图片、按钮、表单</p>
    </div>

    <!-- 底部 -->
    <div class="footer">底部版权信息</div>
</body>
</html>

